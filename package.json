{
  "name": "morpheus",
  "version": "1.0.0",
  "description": "Personal AI executive assistant",
  "main": "server/index.js",
  "bin": "server/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"nodemon server/index.js --watch server\"",
    "build": "vite build",
    "start": "node server/index.js",
    "pkg:mac": "pkg . --target node18-macos-arm64 --output dist/Morpheus-mac",
    "pkg:win": "pkg . --target node18-win-x64 --output dist/Morpheus-win.exe",
    "pkg:linux": "pkg . --target node18-linux-x64 --output dist/Morpheus-linux"
  },
  "pkg": {
    "assets": ["dist/**/*"],
    "scripts": ["server/**/*.js"]
  },
  "dependencies": {
    "express": "^4.19.2",
    "googleapis": "^140.0.0",
    "open": "^10.1.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "pkg": "^5.8.1",
    "vite": "^5.4.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
